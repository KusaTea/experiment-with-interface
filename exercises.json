{"-1": "\u0421\u0436\u0430\u0442\u0438\u0435 \u043a\u0438\u0441\u0442\u0438 \u0432 \u043a\u0443\u043b\u0430\u043a", "0": "\u041e\u0442\u0434\u044b\u0445", "1": "\u0421\u0433\u0438\u0431\u0430\u043d\u0438\u0435 \u0431\u043e\u043b\u044c\u0448\u043e\u0433\u043e \u043f\u0430\u043b\u044c\u0446\u0430", "2": "\u0421\u0433\u0438\u0431\u0430\u043d\u0438\u0435 \u0443\u043a\u0430\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u043f\u0430\u043b\u044c\u0446\u0430", "3": "\u0421\u0433\u0438\u0431\u0430\u043d\u0438\u0435 \u0441\u0440\u0435\u0434\u043d\u0435\u0433\u043e \u043f\u0430\u043b\u044c\u0446\u0430", "4": "\u0421\u0433\u0438\u0431\u0430\u043d\u0438\u0435 \u0431\u0435\u0437\u044b\u043c\u044f\u043d\u043d\u043e\u0433\u043e \u043f\u0430\u043b\u044c\u0446\u0430", "5": "\u0421\u0433\u0438\u0431\u0430\u043d\u0438\u0435 \u043c\u0438\u0437\u0438\u043d\u0446\u0430", "6": "\u0421\u0433\u0438\u0431\u0430\u043d\u0438\u0435 \u0432\u0441\u0435\u0445 \u043f\u0430\u043b\u044c\u0446\u0435\u0432, \u043a\u0440\u043e\u043c\u0435 \u0443\u043a\u0430\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0433\u043e", "7": "\u0421\u0433\u0438\u0431\u0430\u043d\u0438\u0435 \u0432\u0441\u0435\u0445 \u043f\u0430\u043b\u044c\u0446\u0435\u0432, \u043a\u0440\u043e\u043c\u0435 \u0431\u043e\u043b\u044c\u0448\u043e\u0433\u043e", "8": "\u0421\u0433\u0438\u0431\u0430\u043d\u0438\u0435 \u0432\u0441\u0435\u0445 \u043f\u0430\u043b\u044c\u0446\u0435\u0432, \u043a\u0440\u043e\u043c\u0435 \u0431\u043e\u043b\u044c\u0448\u043e\u0433\u043e \u0438 \u0443\u043a\u0430\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0433\u043e", "9": "\u0421\u0433\u0438\u0431\u0430\u043d\u0438\u0435 \u0431\u0435\u0437\u044b\u043c\u044f\u043d\u043d\u043e\u0433\u043e \u043f\u0430\u043b\u044c\u0446\u0430 \u0438 \u043c\u0438\u0437\u0438\u043d\u0446\u0430", "10": "\u041a\u0443\u043b\u0430\u043a", "11": "\u0417\u0430\u0445\u0432\u0430\u0442 \u043a\u0440\u0443\u0433\u043b\u043e\u0433\u043e \u043f\u0440\u0435\u0434\u043c\u0435\u0442\u0430", "12": "\u0417\u0430\u0445\u0432\u0430\u0442 \u043a\u0440\u044e\u043a\u043e\u043c", "13": "\u041a\u043e\u043b\u044c\u0446\u0435\u0432\u043e\u0439 \u0437\u0430\u0445\u0432\u0430\u0442", "14": "\u041f\u0440\u0438\u0437\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0447\u0435\u0442\u044b\u0440\u0435\u0445\u043f\u0430\u043b\u044c\u0446\u0435\u0432\u044b\u0439 \u0437\u0430\u0445\u0432\u0430\u0442", "15": "\u0417\u0430\u0445\u0432\u0430\u0442 \u0434\u043b\u044f \u043f\u0438\u0441\u044c\u043c\u0430", "16": "\u041f\u0438\u043d\u0446\u0435\u0432\u0430\u0442\u044b\u0439 \u0437\u0430\u0445\u0432\u0430\u0442", "17": "\u0414\u0438\u0441\u043a\u043e\u0432\u044b\u0439 \u0437\u0430\u0445\u0432\u0430\u0442", "18": "\u041b\u0430\u0442\u0435\u0440\u0430\u043b\u044c\u043d\u044b\u0439 \u0437\u0430\u0445\u0432\u0430\u0442", "19": "\u041f\u0430\u0440\u0430\u043b\u043b\u0435\u043b\u044c\u043d\u044b\u0439 \u0437\u0430\u0445\u0432\u0430\u0442", "20": "\u0421\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0437\u0430\u0445\u0432\u0430\u0442"}